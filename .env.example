# =============================================================================
# AethOS — full-feature template (active keys; replace placeholders before prod)
# =============================================================================
# Every assignment below is uncommented so copy-paste enables the surface area.
# Secrets use obvious placeholders — never commit real tokens.
# Pydantic env names match these SCREAMING_SNAKE keys (see app/core/config.py).
# Narrative docs: docs/configuration.md, docs/SETUP.md
# =============================================================================

# --- Core ---
APP_NAME=AethOS
AETHOS_BRAND_NAME=AethOS
AETHOS_BRAND_TAGLINE=The Agentic Operating System
APP_ENV=development
DEBUG=true
LOG_JSON_FORMAT=false
API_V1_PREFIX=/api/v1
API_BASE_URL=http://127.0.0.1:8010
# Host port for scripts/install.sh ``start_host`` (must match API_BASE_URL).
PORT=8010

# --- Database (install/bootstrap writes canonical ~/.aethos/data/aethos.db) ---
# DATABASE_URL=   # set automatically by scripts/nexa_bootstrap.py on install

# --- Security (generate strong values for production) ---
NEXA_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
NEXA_WEB_API_TOKEN=CHANGE_ME_ascii_bearer_token_for_mission_control

# --- Web UI / Mission Control login (HTTP headers + setup wizard) ---
NEXA_WEB_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3120,http://127.0.0.1:3120
X_USER_ID=tg_CHANGE_ME_your_telegram_id
TEST_X_USER_ID=tg_CHANGE_ME_your_telegram_id

# --- Owners / Telegram roles (comma-separated numeric Telegram user ids; leave empty for first-linker owner in dev) ---
AETHOS_OWNER_IDS=tg_CHANGE_ME_your_telegram_id
TELEGRAM_OWNER_IDS=

# --- Telegram bot ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
NEXA_TELEGRAM_EMBED_WITH_API=true

# --- LLM providers ---
# USE_REAL_LLM=true does not imply a model call: without any provider that
# satisfies providers_available() (see app/services/llm/completion.py), the
# gateway uses heuristic intent + template/fallback replies — see docs/DESIGN.md §2.3.
USE_REAL_LLM=true
LLM_PROVIDER=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
NEXA_LLM_PROVIDER=auto
NEXA_LLM_MODEL=
NEXA_LLM_API_KEY=
NEXA_LLM_BASE_URL=
# Comma-separated provider ids tried after NEXA_LLM_PROVIDER when the primary errors (see app/services/llm/completion.py).
# When Ollama is primary and any Anthropic/OpenAI/DeepSeek key is set, ``scripts/setup.py`` sets ``anthropic,openai,deepseek`` here.
NEXA_LLM_FALLBACK_PROVIDERS=
NEXA_LLM_TEMPERATURE=0.7
NEXA_LLM_MAX_TOKENS=4096
NEXA_LLM_INTELLIGENCE_LEVEL=balanced
NEXA_LLM_INTELLIGENCE_APPLY_TO_ANTHROPIC=true
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=

# Optional local Ollama (HTTP). NEXA_LLM_PROVIDER=auto alone does not register Ollama in the running app;
# set NEXA_OLLAMA_ENABLED=true and/or NEXA_LLM_PROVIDER=ollama, or NEXA_LOCAL_FIRST=true with auto.
# scripts/setup.py: if `ollama` is on PATH during "Configure .env", it sets NEXA_OLLAMA_ENABLED=true,
# NEXA_LLM_PROVIDER=ollama, NEXA_PURE_LOCAL_LLM_MODE=true, prompts for NEXA_OLLAMA_DEFAULT_MODEL (default phi3:mini for speed),
# best-effort starts `ollama serve` if the HTTP API is down, then runs `ollama pull` for that tag (skip with AETHOS_SETUP_SKIP_OLLAMA_BOOTSTRAP=1).
# With Ollama primary and any Anthropic/OpenAI/DeepSeek key configured, the wizard sets NEXA_LLM_FALLBACK_PROVIDERS=anthropic,openai,deepseek.
# Runtime: ``providers_available()`` is true if merged Anthropic/OpenAI keys exist even when Ollama is down; see app/services/llm/completion.py.
# Intent classification JSON path uses the same providers_available() gate (Ollama-only laptops, no Anthropic/OpenAI key).
# Recommended: phi3:mini (wizard default) for speed; qwen2.5:7b for accuracy — see docs/DESIGN.md §4.3.
NEXA_LOCAL_FIRST=false
NEXA_OLLAMA_ENABLED=false
# NEXA_OLLAMA_BASE_URL=http://127.0.0.1:11434
NEXA_OLLAMA_DEFAULT_MODEL=phi3:mini
# When true with a reachable LLM: intent skips regex fast-paths (always LLM), completion chain tries Ollama first,
# and the response composer skips canned capability short-circuits. When no provider is up, intent uses fallback only.
# Fresh `scripts/setup.py` with `ollama` on PATH sets this to true during "Configure .env" (opt out by editing .env).
NEXA_PURE_LOCAL_LLM_MODE=false
# LLM-first gateway (OpenClaw-like): after tools/NL routes, trust the LLM for most chat (intent ``general_chat``).
# ``scripts/setup.py`` forces this on during Configure .env; set false only if you need legacy deterministic NL.
NEXA_LLM_FIRST_GATEWAY=true

# --- Web search (Brave default; set NEXA_WEB_SEARCH_API_KEY) ---
NEXA_WEB_SEARCH_ENABLED=true
NEXA_WEB_SEARCH_PROVIDER=brave
NEXA_WEB_SEARCH_API_KEY=your-api-key-here
NEXA_WEB_SEARCH_MAX_RESULTS=8

# --- Host executor & local tools (work roots default to repo root when unset) ---
NEXA_HOST_EXECUTOR_ENABLED=true
NEXA_HOST_EXECUTOR_DRY_RUN_DEFAULT=false
NEXA_HOST_EXECUTOR_CHAIN_ENABLED=true
NEXA_HOST_EXECUTOR_CHAIN_MAX_STEPS=10
NEXA_HOST_EXECUTOR_CHAIN_ALLOWED_ACTIONS=
NEXA_NL_TO_CHAIN_ENABLED=true
NEXA_COMMAND_EXECUTION_ENABLED=true
NEXA_COMMAND_TIMEOUT_SECONDS=120
NEXA_ALLOWED_COMMANDS=npm,yarn,pnpm,pip,python,python3,node,npx,git,gh,ls,cat,echo,mkdir,touch,cp,mv,cd,pwd,find,grep,chmod,head,tail,sort,uniq,wc
HOST_EXECUTOR_TIMEOUT_SECONDS=120
HOST_EXECUTOR_MAX_FILE_BYTES=262144

# --- Workspace (NEXA_WORKSPACE_ROOT defaults under home when unset) ---
NEXA_WORKSPACE_MODE=regulated
NEXA_WORKSPACE_STRICT=false
NEXA_APPROVALS_ENABLED=true

# --- Browser (system open/screenshot; Playwright optional for click/fill) ---
NEXA_BROWSER_ENABLED=true
NEXA_BROWSER_AUTOMATION_ENABLED=true
NEXA_BROWSER_PREVIEW_ENABLED=false
NEXA_BROWSER_HEADLESS=false
NEXA_BROWSER_TIMEOUT=30000
NEXA_BROWSER_TIMEOUT_SECONDS=30
NEXA_BROWSER_ALLOWED_DOMAINS=*

# --- Deploy NL (owner-gated CLI) ---
NEXA_GENERIC_DEPLOY_ENABLED=true
NEXA_DEPLOY_AUTO_DETECT=true
NEXA_DEPLOY_TIMEOUT_SECONDS=300
VERCEL_API_TOKEN=
RAILWAY_API_TOKEN=

# --- Observability & reply framing ---
NEXA_OBSERVABILITY_ENABLED=true
NEXA_TRACE_RETENTION_HOURS=24
NEXA_ALERT_CHANNEL=log
NEXA_RESPONSE_FORMAT=beautiful
NEXA_SHOW_PROGRESS_UPDATES=true
NEXA_PROGRESS_UPDATE_INTERVAL_SECONDS=2

# --- Simulation (Mission Control dry-run) ---
NEXA_SIMULATION_ENABLED=true
NEXA_SIMULATION_MAX_DIFF_LINES=500
NEXA_SIMULATION_SANDBOX_MODE=true

# --- Self-improvement (Genesis loop) ---
NEXA_SELF_IMPROVEMENT_ENABLED=true
NEXA_SELF_IMPROVEMENT_GITHUB_ENABLED=false
NEXA_SELF_IMPROVEMENT_GITHUB_TOKEN=
NEXA_SELF_IMPROVEMENT_GITHUB_OWNER=pilotmain
NEXA_SELF_IMPROVEMENT_GITHUB_REPO=aethos
NEXA_SELF_IMPROVEMENT_GITHUB_BASE_BRANCH=main
NEXA_SELF_IMPROVEMENT_AUTO_RESTART=false
NEXA_SELF_IMPROVEMENT_AUTO_REVERT_ENABLED=false

# --- Agent orchestration & autonomy ---
NEXA_AGENT_ORCHESTRATION_ENABLED=true
NEXA_NATURAL_AGENT_INVOCATION=true
NEXA_ASSIGNMENT_AUTO_DISPATCH_DEFAULT=true
NEXA_ASSIGNMENT_AUTO_RECOVER=false
NEXA_ASSIGNMENT_AUTO_RECOVER_WAIT_SECONDS=0
NEXA_INFORMATIONAL_QUESTION_SKIP_LLM=true
NEXA_APPROVALS_PANEL_ENABLED=true
NEXA_SELF_HEALING_ENABLED=true
NEXA_AGENT_ESCALATION_CHAT_ID=
NEXA_AGENT_MAX_PER_CHAT=20
NEXA_AGENT_IDLE_TIMEOUT_SECONDS=3600
NEXA_SUB_AGENT_AUTO_EXECUTE=true
NEXA_AUTO_APPROVE_OWNER=true
NEXA_AUTONOMOUS_GOAL_PLANNING=true
NEXA_EXECUTION_PLANNER_ENABLED=true
NEXA_MAX_CONCURRENT_PLANS=3
NEXA_AGENT_HEARTBEAT_INTERVAL=30
NEXA_STATUS_AUTO_REPORT=true
NEXA_TASK_TIMEOUT_SECONDS=300
NEXA_MAX_CONCURRENT_TASKS=5

# --- Cost-aware routing (optional) ---
NEXA_COST_AWARE_ENABLED=false
NEXA_COST_AWARE_MAX_PER_TASK_USD=0.05
NEXA_COST_AWARE_DEFAULT_PROVIDER=anthropic
NEXA_COST_AWARE_DEFAULT_MODEL=claude-sonnet-4-5
NEXA_COST_AWARE_CHEAP_PROVIDER=anthropic
NEXA_COST_AWARE_CHEAP_MODEL=claude-haiku-4-5
NEXA_COST_AWARE_DEFAULT_MODEL_PER_DOMAIN=
NEXA_COST_AWARE_FALLBACK_PROVIDER=ollama

# --- Operator / dev executor ---
OPERATOR_POLL_SECONDS=20
OPERATOR_AUTO_RUN_LOCAL_TOOLS=true
OPERATOR_AUTO_RUN_DEV_EXECUTOR=true
DEV_EXECUTOR_ON_HOST=false

# --- Cron / scheduled jobs ---
NEXA_CRON_ENABLED=true
NEXA_CRON_DEFAULT_TIMEZONE=UTC
NEXA_CRON_API_TOKEN=

# --- Web access & scraping ---
NEXA_WEB_ACCESS_ENABLED=true
NEXA_SCRAPING_ENABLED=true

# --- Marketplace / skills ---
NEXA_CLAWHUB_ENABLED=true
NEXA_MARKETPLACE_PANEL_ENABLED=true
NEXA_MARKETPLACE_FEATURED_PANEL_ENABLED=true

# --- Privacy / gateway ---
NEXA_STRICT_PRIVACY_MODE=true
NEXA_NETWORK_EGRESS_MODE=allowlist
NEXA_PRIVACY_FIREWALL_ENABLED=true
NEXA_REDACT_PII_BEFORE_EXTERNAL_API=true
NEXA_BLOCK_SECRETS_TO_EXTERNAL_API=true
NEXA_CONVERSATION_MEMORY_ENABLED=true
NEXA_CONVERSATION_MEMORY_TURNS=10

# --- Access & safety ---
NEXA_ACCESS_PERMISSIONS_ENFORCED=false
NEXA_SAFETY_POLICY_STRICT=false
NEXA_NETWORK_EXTERNAL_SEND_ENFORCED=false
NEXA_SECRET_EGRESS_ENFORCED=false

# --- Misc defaults ---
DEFAULT_TIMEZONE=America/New_York
DEFAULT_MAX_TASKS=3
DEFAULT_PLANNING_STYLE=gentle
FOLLOWUP_POLL_SECONDS=30

# --- AethOS orchestration runtime (OpenClaw Phase 1; JSON in ~/.aethos/aethos.json) ---
# Background scheduler tick interval (seconds). Lower only for local debugging.
AETHOS_ORCHESTRATION_TICK_SEC=10
# Allow orchestration scheduler during pytest (default off when NEXA_PYTEST=1).
# AETHOS_ORCHESTRATION_ENABLE_IN_PYTEST=1
# Short scheduler tick in tests (internal).
# AETHOS_ORCHESTRATION_TEST_FAST=1
# Bounded growth + execution retry caps (safe defaults; tune for long-running hosts).
AETHOS_RUNTIME_EVENT_BUFFER_LIMIT=500
AETHOS_PLANNING_RECORD_LIMIT=500
AETHOS_PLANNING_OUTCOME_LIMIT=500
AETHOS_RUNTIME_QUARANTINE_LIMIT=80
AETHOS_RUNTIME_BACKUP_LIMIT=25
AETHOS_TASK_ARTIFACT_LIMIT=200
AETHOS_PLAN_CHECKPOINT_LIMIT=500
AETHOS_QUEUE_LIMIT=5000
AETHOS_STEP_MAX_RETRIES=3

# --- Phase 2 — privacy / PII / local-first (additive; default observe) ---
# Privacy posture: off | observe | redact | block | local_only
AETHOS_PRIVACY_MODE=observe
AETHOS_PRIVACY_AUDIT_ENABLED=true
AETHOS_PII_REDACTION_ENABLED=false
AETHOS_LOCAL_FIRST_ENABLED=false
AETHOS_EXTERNAL_EGRESS_GUARD_ENABLED=false
AETHOS_REQUIRE_LOCAL_MODEL=false
AETHOS_LOCAL_MODEL_PROVIDER=ollama
# AETHOS_LOCAL_MODEL_NAME=   # optional local model id when using local-first routing
AETHOS_ALLOW_EXTERNAL_FALLBACK=true
AETHOS_ENCRYPTION_AT_REST_ENABLED=false
# AETHOS_ENCRYPTION_KEY_SOURCE=env   # env | none | file
# AETHOS_ENCRYPTION_KEY=   # optional at-rest key material (never commit real secrets)
