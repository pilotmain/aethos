APP_NAME=Nexa
APP_ENV=development
DEBUG=true
# Optional: JSON log lines (one object per line) for aggregation; API startup only. See docs/WEEK2_HOST_ACTION_CHAINS.md (Observability).
# LOG_JSON_FORMAT=false

# Week 4 — sub-agent registry (in-memory; single API worker). See docs/AGENT_ORCHESTRATION.md
# NEXA_AGENT_ORCHESTRATION_ENABLED=false
# NEXA_AGENT_MAX_PER_CHAT=5
# NEXA_AGENT_IDLE_TIMEOUT_SECONDS=3600
# Phase 3: run allowlisted host payloads in-process (loose; audit). Default: queue jobs.
# NEXA_AGENT_ORCHESTRATION_AUTOQUEUE=false
# Week 5 — in-process rate limits (single API worker; see sub_agent_rate_limit)
# NEXA_AGENT_RATE_LIMIT_PER_AGENT=30
# NEXA_AGENT_RATE_LIMIT_PER_CHAT=80
# NEXA_AGENT_RATE_LIMIT_PER_DOMAIN=40
# NEXA_AGENT_RATE_LIMIT_WINDOW_SECONDS=60
# Week 5 — auto-queue allowlists (empty NEXA_AGENT_AUTOQUEUE_ALLOWLIST_CHATS = any chat)
# NEXA_AGENT_AUTOQUEUE_ALLOWLIST_CHATS=
# NEXA_AGENT_AUTOQUEUE_ALLOWLIST_DOMAINS=git
# After N successful in-process auto-queue runs per sub-agent, force approval queue (0 = off)
# NEXA_AGENT_AUTOQUEUE_REQUIRE_APPROVAL_AFTER=0
# Run idle sub-agent cleanup at most this often when handling orchestration turns (seconds)
# NEXA_AGENT_CLEANUP_INTERVAL_SECONDS=300
# Week 5.5 — auto-approve trusted chats/domains (skip Jobs approval; host executor executes in-process)
# NEXA_AUTO_APPROVE_ENABLED=false
# NEXA_AUTO_APPROVE_CHATS=
# NEXA_AUTO_APPROVE_DOMAINS=git
# NEXA_AUTO_APPROVE_LOG_ONLY=false
API_V1_PREFIX=/api/v1
DATABASE_URL=sqlite:///./overwhelm_reset.db
# Local dev: ./scripts/nexa_next_local_all.sh start — defaults to docker compose up --build -d (db+api+bot) + host Next.js.
# Host-only stack (uvicorn + bot on host): NEXA_NEXT_LOCAL_FULL_STACK=0 ./scripts/nexa_next_local_all.sh start
# Db-only for host processes: ./scripts/docker_postgres_up.sh (also used internally when FULL_STACK=0 and Postgres URL).

# Dev-only: POST /api/v1/mission-control/database/purge-sql hard-deletes MC-related rows for the authenticated user (orchestration, jobs, org, optional audit).
# Deleting the SQLite file above wipes the entire DB for all users; use purge-sql to clear one Nexa user id without removing others.
NEXA_MISSION_CONTROL_SQL_PURGE=false

# --- Web UI (Next.js) + Mission Control / authenticated API ---
# Comma-separated browser Origins for CORS. The API also always allows scripts/nexa_next_local_all.sh
# web ports http://localhost:3120 and http://127.0.0.1:3120 (Next on 3120 → API on 8120).
# Add more if you use a custom port. If this var is empty, defaults include :3000 and :3120.
# NEXA_WEB_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
#
# If set, every browser request must send: Authorization: Bearer <same value>. Paste it on the login page.
# NEXA_WEB_API_TOKEN=

# Set USE_REAL_LLM=true (lowercase) and at least one API key so the composer and intent router use the LLM.
# No quotes. Example: USE_REAL_LLM=true
# Optional: LLM_PROVIDER=anthropic (documentation only; app tries Anthropic first when ANTHROPIC_API_KEY is set)
USE_REAL_LLM=false
LLM_PROVIDER=

# Primary LLM (Anthropic); OpenAI is optional fallback when Anthropic fails or returns empty
ANTHROPIC_API_KEY=
# Use a current ID (see https://docs.anthropic.com/en/docs/about-claude/models)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Fallback LLM (OpenAI) — used if USE_REAL_LLM=true and Anthropic is unavailable or errors
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Phase 11 — primary provider for safe_llm + call_primary_llm_* (app.services.llm)
# NEXA_LLM_PROVIDER=auto|openai|anthropic|deepseek|ollama|openrouter
# auto = try anthropic → openai → deepseek → openrouter → ollama (only providers with keys / Ollama when enabled)
NEXA_LLM_PROVIDER=auto
# NEXA_LLM_MODEL=  # optional override for the active NEXA_LLM_PROVIDER
# NEXA_LLM_API_KEY=  # optional: single key for the selected NEXA_LLM_PROVIDER
# NEXA_LLM_BASE_URL=  # optional (OpenAI-compatible base for openai when set)
# NEXA_LLM_FALLBACK_PROVIDERS=openai,ollama
# NEXA_LLM_TEMPERATURE=0.7
# NEXA_LLM_MAX_TOKENS=4096
#
# --- DeepSeek (OpenAI-compatible; get key at https://platform.deepseek.com/api_keys) ---
# After DEEPSEEK_API_KEY is set: change NEXA_LLM_PROVIDER above from auto to deepseek.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
#
# --- OpenRouter (optional) ---
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Phase 6 — pluggable skills (YAML manifests + plugin registry). See docs/SKILLS_SYSTEM.md
# ClawHub-compatible HTTP API root (search / skills / download endpoints vary by host).
# NEXA_CLAWHUB_API_BASE=https://clawhub.com/api/v1
# Optional absolute path for URL installs and future unpacked packages (default: <repo>/data/nexa_plugin_skills).
# NEXA_PLUGIN_SKILLS_ROOT=

DEFAULT_TIMEZONE=America/New_York
FOLLOWUP_POLL_SECONDS=30
DEFAULT_MAX_TASKS=3
DEFAULT_PLANNING_STYLE=gentle
# Published API port on the host (Docker maps 8010 → 8000 in container). Native uvicorn: use same port or override.
API_BASE_URL=http://localhost:8010
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# Slack (optional) — HTTP Events API *or* Bolt Socket Mode (Phase 12.1). Do not enable both transports
# against the same app/workspace without filtering — you may receive duplicate messages.
# Events API Request URL: POST {API}/api/v1/slack/events
# Interactivity Request URL: POST {API}/api/v1/slack/interactions
# Socket Mode: SLACK_APP_TOKEN=xapp-… + NEXA_SLACK_ENABLED=true (API lifespan starts Bolt handler).
NEXA_SLACK_ENABLED=false
# Optional — route emoji reactions through the gateway (can be noisy in busy channels).
# NEXA_SLACK_REACTIONS_ENABLED=false
SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=  # xapp- — required for Socket Mode; omit for HTTP Events only
SLACK_SIGNING_SECRET=

# Phase 13 — cron scheduling (AsyncIOScheduler in API; SQLite job store; Telegram/Slack/CLI use Bearer to POST /api/v1/cron/*)
# NEXA_CRON_ENABLED=true
# NEXA_CRON_DEFAULT_TIMEZONE=UTC
# NEXA_CRON_JOB_STORE=sqlite:///./data/nexa_cron_jobs.sqlite
# Required for chat commands + nexa_cli cron: must match between bot CLI and API process.
# NEXA_CRON_API_TOKEN=

# Phase 14 — browser automation (Playwright/Chromium in API; Bearer same as cron for /api/v1/browser/*)
# NEXA_BROWSER_ENABLED=true
# NEXA_BROWSER_HEADLESS=true
# NEXA_BROWSER_TIMEOUT=30000
# NEXA_BROWSER_SCREENSHOT_DIR=/app/data/screenshots

# Phase 15 — active memory (chunked recall; optional Ollama via NEXA_OLLAMA_EMBEDDINGS_ENABLED)
# NEXA_ACTIVE_MEMORY_ENABLED=false
# NEXA_ACTIVE_MEMORY_ALWAYS=false
# NEXA_ACTIVE_MEMORY_TOP_K=8
# NEXA_ACTIVE_MEMORY_MIN_SCORE=0.12
# NEXA_ACTIVE_MEMORY_MAX_CHARS=4000
# NEXA_ACTIVE_MEMORY_CHUNK_CHARS=800
# NEXA_ACTIVE_MEMORY_CHUNK_OVERLAP=100
# NEXA_ACTIVE_MEMORY_MAX_ENTRIES_SCAN=200
# NEXA_ACTIVE_MEMORY_INGEST_ENABLED=true

# Email (optional) — POST {API}/api/v1/email/inbound with header X-Email-Webhook-Secret
# Permission links in outbound mail use the same secret for HMAC tokens.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_WEBHOOK_SECRET=

# WhatsApp Cloud API (optional) — Meta developer app + WhatsApp product
# Webhook URL: GET/POST {API}/api/v1/whatsapp/webhook (subscribe verification + inbound messages)
# Optional WHATSAPP_APP_SECRET verifies X-Hub-Signature-256 on POST when set.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# SMS / Twilio (optional) — POST {API}/api/v1/sms/inbound (application/x-www-form-urlencoded)
# Set TWILIO_AUTH_TOKEN to validate X-Twilio-Signature on inbound webhooks.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Apple Messages for Business (provider, Phase 11) — POST {API}/api/v1/apple-messages/inbound (JSON)
# Provider URL is the outbound send endpoint you receive from your Apple-approved messaging partner.
APPLE_MESSAGES_PROVIDER_URL=
APPLE_MESSAGES_ACCESS_TOKEN=
APPLE_MESSAGES_BUSINESS_ID=
# Optional but recommended: inbound verification header X-Apple-Messages-Webhook-Secret (matches this value).
APPLE_MESSAGES_WEBHOOK_SECRET=

# Comma-separated numeric Telegram user ids. Required for production multi-user; when unset, the
# first user who /start is "owner" (local dev) and other chatters are guests.
TELEGRAM_OWNER_IDS=
# Optional: users who can use read-only stack commands and /learning list (not full Dev/Ops)
TELEGRAM_TRUSTED_USER_IDS=
# Optional: block list (these ids get no access)
# TELEGRAM_BLOCKED_USER_IDS=

# Per-user API keys in the DB (BYOK) are encrypted with a server secret. Generate a long random string.
# NEXA_SECRET_KEY=

# Cursor Cloud Agents API (Phase 1) — POST https://api.cursor.com/v0/agents with Bearer CURSOR_API_KEY.
# Key from Cursor Dashboard → Integrations.
# CURSOR_ENABLED=false
# CURSOR_API_KEY=
# CURSOR_API_BASE=https://api.cursor.com
# CURSOR_DEFAULT_MODEL=composer-2
# (model / auto-PR not sent on v0 minimal body yet — reserved for API updates)
# CURSOR_DEFAULT_REPO_URL=https://github.com/your-org/your-repo
# CURSOR_DEFAULT_BRANCH=main
# Optional: comma-separated URL prefixes allowed for creates
# CURSOR_ALLOWED_REPO_URLS=https://github.com/your-org
# CURSOR_AUTO_CREATE_PR=false
# CURSOR_HTTP_TIMEOUT_SECONDS=120
# CURSOR_POLL_INTERVAL_SECONDS=3
# CURSOR_MAX_POLL_ITERATIONS=60

# Dev executor (highest priority first):
# 1) DEV_AGENT_COMMAND — your internal / OpenAI or other non-interactive agent. Shell-style one line;
#    the process receives the generated dev prompt on stdin. Use for production-style runs.
# 2) If unset, the executor may fall back to the local Codex CLI (with --skip-git-repo-check) when
#    DEV_AGENT_CODEX_PATH exists — but only in a *git* work tree (or set next line).
# 3) If no command and no Codex: job stops at the written .agent_tasks/dev_job_N.md for manual Cursor.
# DEV_AGENT_DISABLE_CODEX_FALLBACK=true — never auto-invoke Codex; only your command or manual.
# DEV_AGENT_CODEX_ALLOW_NO_GIT=true — allow the Codex fallback even when the project has no .git
#    (not recommended: Codex often fails here; prefer git init, DEV_AGENT_COMMAND, or manual Cursor).
# DEV_AGENT_CODEX_PATH=/path/to/codex — override Codex binary path.
DEV_AGENT_COMMAND=
# Autonomous Aider (unattended CLI): requires git, runs before Cursor handoff path
# pip install aider-chat  (then `aider --help`)
# Example:
# DEV_AGENT_AUTO_RUN=true
# DEV_AGENT_COMMAND=aider --yes --no-auto-commits --message-file {task_file}
# DEV_APPROVAL_REQUIRED=true
# DEV_AUTO_COMMIT=false
# DEV_AUTO_PUSH=false
# DEV_AGENT_TEST_COMMAND=python -m pytest
# Deeper approval / revert flow uses statuses: waiting_approval -> (Telegram) approve|reject|show diff
# Hardening: block dirty worktree, policy on queue, audit log, secret scan; optional PR
# Reliability: cap concurrent in-flight dev jobs, worker id for locks/heartbeat, agent/test timeouts
# DEV_AGENT_MAX_ACTIVE_JOBS=1
# DEV_WORKER_ID=hostname:pid
# DEV_AGENT_TIMEOUT_SECONDS=1800
# DEV_AGENT_TEST_TIMEOUT_SECONDS=600
# DEV_AGENT_ALLOW_DIRTY_TREE=false
# DEV_AUTO_CREATE_PR=false
# DEV_AGENT_DISABLE_CODEX_FALLBACK=false
# DEV_AGENT_CODEX_PATH=

# Operator loop:
# - The API scheduler can advance queued local-tool/dev-executor jobs automatically.
OPERATOR_POLL_SECONDS=20
OPERATOR_AUTO_RUN_LOCAL_TOOLS=true
OPERATOR_AUTO_RUN_DEV_EXECUTOR=true
# Set true to skip the first `approve job #N` for dev jobs (dev_executor, kind=dev_task). Trusted machine only.
OPERATOR_AUTO_APPROVE_QUEUED_DEV_JOBS=false
OPERATOR_AUTO_APPROVE_REVIEW=true
# If true, only some commit requests auto-approve (title heuristics). If false, use the next line instead.
OPERATOR_AUTO_APPROVE_COMMIT_SAFE=false
# Trusted personal machine: auto-approve every final commit (no title filter). Use with care.
OPERATOR_AUTO_APPROVE_ALL_COMMITS=false

# Full "hands off" example (merge or see env.autonomy.example)

# Safe LLM gateway (sanitize + minimize + path allowlist before OpenAI/Anthropic)
SAFE_LLM_MODE=true
SAFE_LLM_MAX_CHARS=6000
SAFE_LLM_ALLOW_RAW_CODE=false
SAFE_LLM_ALLOWED_ROOTS=app,scripts,tests
SAFE_LLM_BLOCKED_PATTERNS=.env,.ssh,credentials,secrets,__pycache__,.venv,node_modules

# Prompt posture: developer = governed-orchestrator wording + runtime capability truth (avoid false "read-only");
# regulated = more conservative defaults. Unrecognized values fall back to regulated.
# NEXA_WORKSPACE_MODE=regulated
# NEXA_WORKSPACE_MODE=developer
# Approval gating (Web/Telegram permission cards). Set false **only with** NEXA_WORKSPACE_MODE=developer for local autonomy testing.
# NEXA_APPROVALS_ENABLED=true
# NEXA_APPROVALS_ENABLED=false
# Optional audit string when dev autonomy bypass fires (`access.permission.bypassed`).
# NEXA_APPROVAL_BYPASS_REASON=local development testing

# Governed agent runtime (sessions_spawn, background_heartbeat, mission reports). Restart API + bot after changing.
# NEXA_AGENT_TOOLS_ENABLED=false

# Phase 22 — persistent memory layer, scheduler jobs, local-first routing hints
# NEXA_MEMORY_LAYER_ENABLED=true
# Optional directory for per-user markdown+json memory files (default: ./data/nexa_memory under repo)
# NEXA_MEMORY_DIR=
# Prefer local_stub before remote providers when a tool maps to openai/anthropic (Ollama wiring is separate).
# NEXA_LOCAL_FIRST=false
# Optional when wiring local LLMs (documented for future provider adapters)
# NEXA_OLLAMA_BASE_URL=http://127.0.0.1:11434
# Parallel agent waves for non-SQLite DBs only (experimental).
# NEXA_MISSION_PARALLEL_TASKS=false

# Phase 23 — AI dev OS (workspaces + allowlisted commands in registered repos)
# Comma-separated absolute path prefixes allowed for dev workspace registration (empty → workspace root + repo root).
# NEXA_DEV_WORKSPACE_ROOTS=
# Comma-separated allowlisted commands (exact match after whitespace normalization).
# NEXA_DEV_ALLOWED_COMMANDS=git status,git diff,git branch,git log --oneline -n 20,npm test,npm run test,pytest,python -m pytest
# NEXA_DEV_COMMAND_TIMEOUT_SECONDS=180
# Phase 24 — coding agents (Aider / Cursor / Claude Code / Codex) + PR stub
# NEXA_AIDER_ENABLED=true
# NEXA_AIDER_COMMAND=aider
# NEXA_CURSOR_AGENT_ENABLED=false
# CURSOR_API_KEY=
# NEXA_CURSOR_AGENT_REQUIRE_COST_BUDGET=true
# NEXA_CURSOR_AGENT_MAX_COST_USD=2.0
# NEXA_CLAUDE_CODE_ENABLED=false
# NEXA_CODEX_ENABLED=false
# NEXA_GITHUB_PR_ENABLED=false
# GITHUB_TOKEN=
# Phase 25 — POST /api/v1/dev/runs accepts ``max_iterations`` (1–20) for test/fix loops.

# Nexa Ops (provider-agnostic). Execution uses fixed `argv` only; never user shell.
# NEXA_OPS_PROVIDER — used by default project seed; registry keys include `railway`, `local`, `local_docker`
NEXA_OPS_PROVIDER=local
# NEXA_DEFAULT_ENVIRONMENT — default for seeded `nexa` project
# NEXA_DEFAULT_ENVIRONMENT=staging
# NEXA_OPS_DRY_RUN=1 — do not run real deploy/restart/rollback; keep 1 until approved + host is ready
NEXA_OPS_DRY_RUN=1
# Optional: NEXA_USE_RAILWAY=1 — document-only hint that Railway CLI is in use
# NEXA_OPS_LOGS_SOURCE=file|provider — `file` uses log files or docker; `provider` uses the selected connector
# NEXA_OPS_LOGS_SOURCE=file
# NEXA_OPS_STATUS_VIA=provider — append `provider.status()` to health (when DRY_RUN=0)
# NEXA_OPS_RESTART_VIA=provider|docker — default provider when set to provider
# NEXA_OPS_RAILWAY_STAGING= — optional: value for RAILWAY_ENVIRONMENT subprocess env on staging deploys
# NEXA_OPS_RAILWAY_PROD= — optional: same for production deploys

# Public read-only web (httpx + HTML; not a full browser)
# NEXA_WEB_ACCESS_ENABLED=true
# NEXA_WEB_FETCH_TIMEOUT_SECONDS=15
# NEXA_WEB_MAX_BYTES=1500000
# NEXA_WEB_RESPECT_ROBOTS=true

# Optional: owner-only headless browser preview (Playwright) for public URLs — off by default
# NEXA_BROWSER_PREVIEW_ENABLED=false
# NEXA_BROWSER_PREVIEW_TIMEOUT_MS=35000
# Optional: Playwright click/fill on public URLs (still no logins). Requires preview enabled + Chromium installed.
# NEXA_BROWSER_AUTOMATION_ENABLED=false

# Optional: public web search (tool-based: titles, snippets, URLs from a provider — not “random browse”)
# Off by default. To enable: set enabled + one provider + API key from that vendor, then restart API and bot.
# NEXA_WEB_SEARCH_ENABLED=true
# NEXA_WEB_SEARCH_PROVIDER=brave
# NEXA_WEB_SEARCH_API_KEY=
# NEXA_WEB_SEARCH_MAX_RESULTS=5
# Alternatives (pick one provider and use its key):
# NEXA_WEB_SEARCH_PROVIDER=tavily
# NEXA_WEB_SEARCH_PROVIDER=serpapi
# Do not commit real API keys. Verify: python scripts/verify_web_search.py "test query"

# Host executor: allowlisted local actions (git_status, pytest, scoped file I/O, git commit) via
# local_tool jobs — requires approval; executed by scripts/local_tool_worker.py on the worker host.
# Off by default. Set true only on a machine you trust.
# NEXA_HOST_EXECUTOR_ENABLED=false
# Optional: cwd/file base (defaults to Nexa repo root). With Docker, bind-mount your repos in
# docker-compose.override.yml (copy from docker-compose.override.example.yml) and set this to the
# container-side path, e.g. HOST_EXECUTOR_WORK_ROOT=/app/repos or /Users/YOUR_USERNAME — see
# docs/WEEK2_HOST_ACTION_CHAINS.md.
# HOST_EXECUTOR_WORK_ROOT=/app/repos
# HOST_EXECUTOR_TIMEOUT_SECONDS=120
# HOST_EXECUTOR_MAX_FILE_BYTES=262144

# Chain host action: batch multiple allowlisted steps in one job (one approval). Off by default.
# NEXA_HOST_EXECUTOR_CHAIN_ENABLED=false
# NEXA_HOST_EXECUTOR_CHAIN_MAX_STEPS=10
# NEXA_HOST_EXECUTOR_CHAIN_ALLOWED_ACTIONS=
# NL → readme+commit+push chain (narrow phrases); requires NEXA_HOST_EXECUTOR_CHAIN_ENABLED=true
# NEXA_NL_TO_CHAIN_ENABLED=false

# P0 — Operator mode: act on clear CLI/deploy intent with fewer confirmation loops (pairs with execution_loop).
# When true, medium-confidence dev auto-run skips the extra “confirm” prompt; gateway scrubs repeated nag phrases.
# NEXA_OPERATOR_MODE=false
# Phase Next — mutating operator actions (require NEXA_HOST_EXECUTOR_ENABLED=true on the worker).
# NEXA_OPERATOR_ALLOW_WRITE=false
# NEXA_OPERATOR_ALLOW_DEPLOY=false
# NEXA_OPERATOR_AUTO_RETRY=false
# When operator mode is on, re-read ``PULSE.md`` each turn and append standing orders (plus deploy-skip hints from PULSE).
# NEXA_PULSE_INJECTION=true
# When operator mode is on, prepend a short “Understood / operator run” preamble to operator + execution-loop replies.
# NEXA_OPERATOR_PROACTIVE_INTRO=true
# When operator mode is on, treat one-word replies like “go” / “approve” as external-exec prefs (probe + deploy_when_ready + local CLI default).
# NEXA_OPERATOR_AUTONOMOUS_EXTERNAL_FLOW=false
# When operator mode is on, shorten access/Railway copy, bypass external-exec access gate, and scrub nag phrases from operator/execution replies.
# NEXA_OPERATOR_ZERO_NAG=true
# Hold pasted provider tokens in this API process RAM for bounded CLI subprocess env only (never logged or echoed).
# NEXA_OPERATOR_SESSION_CREDENTIAL_REUSE=true
# Ultra-short operator / execution replies (collapse progress prose; keep fenced CLI output).
# NEXA_OPERATOR_PRECISE_SHORT_RESPONSES=true
# Run vercel/gh/railway/git via bash -lc after sourcing nvm.sh + rc files (recommended on macOS + nvm).
# NEXA_OPERATOR_CLI_PROFILE_SHELL=true
# When the worker cannot see nvm/Homebrew PATH, set full binaries from `which vercel` / `which gh` on that host.
# NEXA_OPERATOR_CLI_VERCEL_ABS=
# NEXA_OPERATOR_CLI_GH_ABS=
# NEXA_OPERATOR_CLI_GIT_ABS=
# NEXA_OPERATOR_CLI_RAILWAY_ABS=
# Log argv rewrite + whether configured paths exist on this worker (set 1 while debugging Docker/systemd env).
# NEXA_OPERATOR_CLI_ABS_DEBUG=
# Optional LLM/CLI binaries for backend registry (codex/claude); persistent stdio sessions not implemented yet.
# CODEX_CLI_PATH=
# CLAUDE_CLI_PATH=
# CODEX_PERSISTENT_SESSION=false
# CLAUDE_PERSISTENT_SESSION=false
# When vercel/gh fail with “not logged in”, append guided docker exec / host login steps (see docs/GUIDED_CLI_LOGIN_FOR_OPERATORS.md).
# NEXA_OPERATOR_CLI_AUTH_GUIDANCE=true
# Container name shown in docker exec examples if yours differs from nexa-api.
# NEXA_OPERATOR_GUIDANCE_DOCKER_CONTAINER=nexa-api
# When true (default), medium-confidence workspace auto-run may ask for confirmation unless operator mode is on.
# NEXA_EXECUTION_CONFIRM_MEDIUM=true

# Phase 58 — External execution (Railway chat pipeline): bounded CLI investigation after user confirms prefs.
# Appends verified command output to the reply; does not deploy or redeploy.
# Set false to keep acknowledgment text only (no local subprocesses from this flow).
# NEXA_EXTERNAL_EXECUTION_RUNNER_ENABLED=true
# Railway auth on the worker process (CLI also respects login); used by external_execution access checks + CLI:
# RAILWAY_TOKEN=
# RAILWAY_API_TOKEN=
# GitHub token for PR/push flows (optional; same variable as Phase 24 coding / PR stub):
# GITHUB_TOKEN=

# Generated documents: stored under .runtime/generated_documents/ (per user). No cleanup cron yet.
# NEXA_DOCUMENT_RETENTION_DAYS=30

# Enterprise governance (Phase 13) — per-org channel policies, RBAC, audit export
# NEXA_GOVERNANCE_ENABLED=false
# Optional default org for single-tenant / local testing (users without users.organization_id)
# NEXA_DEFAULT_ORGANIZATION_ID=
# Local dev only: auto-create default org + owner membership on first governance request
# NEXA_AUTO_CREATE_DEFAULT_ORG=false

# --- Nexa Next (gateway + privacy firewall + Mission Control state API) ---
# Privacy firewall gates payloads before external LLM/tool calls (see app/services/privacy_firewall/).
NEXA_PRIVACY_FIREWALL_ENABLED=true
NEXA_REDACT_PII_BEFORE_EXTERNAL_API=true
NEXA_BLOCK_SECRETS_TO_EXTERNAL_API=true

# Phase 10 — production hardening (provider gateway + audit)
# Block OpenAI/Anthropic/local HTTP providers except local_stub (kill switch).
# NEXA_DISABLE_EXTERNAL_CALLS=false
# Sliding window per user_id (requests per rolling minute; 0 = unlimited).
# NEXA_PROVIDER_RATE_LIMIT_PER_MINUTE=120
# Expose GET /api/v1/admin/privacy/events and /api/v1/admin/external-calls (404 when false).
# NEXA_ADMIN_ENDPOINTS_ENABLED=false

# Phase 11 — production stabilization (timeouts/retries, mission max runtime, retention sweeps)
# NEXA_RELEASE_VERSION=phase-11
# NEXA_PROVIDER_TIMEOUT_SECONDS=15
# NEXA_PROVIDER_MAX_RETRIES=3
# NEXA_MISSION_MAX_RUNTIME_SECONDS=60
# NEXA_DATA_RETENTION_DAYS=7
# NEXA_RETENTION_SWEEP_INTERVAL_SECONDS=3600

# Phase 38 — token economy (every outbound provider call is estimated + budget-checked in app/services/providers/gateway.py)
# Conservative char/4 token estimate; block when over budget if NEXA_BLOCK_OVER_TOKEN_BUDGET=true.
NEXA_TOKEN_BUDGET_PER_REQUEST=8000
NEXA_TOKEN_BUDGET_PER_DAY=100000
NEXA_COST_BUDGET_PER_DAY_USD=5.0
NEXA_BLOCK_OVER_TOKEN_BUDGET=true

# Phase 39 — local-first + autonomy (Ollama routes via gateway when NEXA_LOCAL_FIRST=true)
# NEXA_LOCAL_FIRST=false
# NEXA_OLLAMA_ENABLED=false
# NEXA_OLLAMA_BASE_URL=http://127.0.0.1:11434
# NEXA_OLLAMA_DEFAULT_MODEL=llama3
# Semantic memory ranking via Ollama /api/embeddings (needs NEXA_OLLAMA_ENABLED + reachable Ollama).
# NEXA_OLLAMA_EMBEDDINGS_ENABLED=false
# Parallel mission tasks (non-SQLite recommended); SQLite requires explicit opt-in:
# NEXA_MISSION_PARALLEL_TASKS=false
# NEXA_MISSION_PARALLEL_ALLOW_SQLITE=false
# Background heartbeat (emit_runtime_event system.heartbeat):
# NEXA_HEARTBEAT_ENABLED=false
# NEXA_HEARTBEAT_INTERVAL_SECONDS=300

# Phase 42 — execution upgrades (Discord bot, Slack gateway bridge, autonomy flag)
# Discord (requires: pip install discord.py; enable Message Content intent in Discord Developer Portal)
# NEXA_DISCORD_ENABLED=false
# NEXA_DISCORD_BOT_TOKEN=
# Optional: map every Discord user message to one Nexa app user id (recommended for single-owner bots).
# NEXA_DISCORD_APP_USER_ID=
# Slack: route Events API text through NexaGateway route_inbound instead of legacy channel gateway.
# NEXA_SLACK_ROUTE_INBOUND=false
# Surfaces in Mission Control runtime; pair with scheduler jobs + heartbeat for meaningful autonomy.
# NEXA_AUTONOMOUS_MODE=false
# Phase 43 — with NEXA_AUTONOMOUS_MODE, also run each DB long-running tick through NexaGateway (optional).
# NEXA_LONG_RUNNING_GATEWAY_TICK=false
# Phase 45 — run pending autonomous tasks through NexaGateway on each heartbeat (with NEXA_HEARTBEAT_ENABLED).
# NEXA_AUTONOMY_EXECUTION_ENABLED=true
# NEXA_AUTONOMY_MAX_TASKS_PER_CYCLE=5
# NEXA_AUTONOMY_MAX_USERS_PER_HEARTBEAT=12

# Phase 13 — strict privacy lockdown (block OpenAI/Anthropic; only local_stub for LLM-style tools)
# NEXA_STRICT_PRIVACY_MODE=false

# Phase 18 — use ingress-style post-provider detection (stricter; more false positives)
# NEXA_DETECTION_STRICT_MODE=false

# Phase 19 — user privacy stance: standard | strict | paranoid (see PrivacyTrustPanel / gateway)
# NEXA_USER_PRIVACY_MODE=standard

# Phase 33 — production posture (WARNING logs, FastAPI debug off, Mission Control strict-privacy hint on)
# NEXA_PRODUCTION_MODE=false

# Phase 16 — Agent Orchestration Enhancements (gateway /delegate + REST delegate; Mission Control auth on REST)
# NEXA_ORCHESTRATION_ENABLED=false
# NEXA_ORCHESTRATION_MAX_DELEGATES=5
# NEXA_ORCH_MAX_PARALLEL_AGENTS=3
# NEXA_ORCH_DELEGATION_TIMEOUT_MS=30000
# NEXA_ORCH_REQUIRE_APPROVAL=false

# Phase 17 — ClawHub marketplace (install/update/remove plugin skills; REST uses NEXA_CRON_API_TOKEN)
# NEXA_CLAWHUB_ENABLED=true
# NEXA_CLAWHUB_API_BASE=https://clawhub.com/api/v1
# NEXA_CLAWHUB_SKILL_ROOT=/app/data/skills
# NEXA_CLAWHUB_TRUSTED_PUBLISHERS=nexa,openclaw,community
# NEXA_CLAWHUB_REQUIRE_SIGNATURE=false
# NEXA_CLAWHUB_AUTO_UPDATE=false
# NEXA_CLAWHUB_REQUIRE_INSTALL_APPROVAL=false

# Phase 18a — Multi-modal (vision / audio / image gen; 18b+ adds providers — docs/PHASE_18_MULTIMODAL.md)
# NEXA_MULTIMODAL_ENABLED=false
# NEXA_MULTIMODAL_VISION_ENABLED=false
# NEXA_MULTIMODAL_VISION_PROVIDER=auto
# NEXA_MULTIMODAL_VISION_MODEL=
# NEXA_GEMINI_API_KEY=  # optional; when NEXA_MULTIMODAL_VISION_PROVIDER=gemini
# NEXA_AUDIO_INPUT_ENABLED=false
# NEXA_AUDIO_TRANSCRIPTION_PROVIDER=openai
# NEXA_AUDIO_OUTPUT_ENABLED=false
# NEXA_IMAGE_GEN_ENABLED=false
# NEXA_IMAGE_GEN_PROVIDER=openai
# NEXA_MULTIMODAL_MAX_IMAGE_MB=10
# NEXA_MULTIMODAL_MAX_AUDIO_SECONDS=300
# NEXA_MULTIMODAL_MAX_IMAGE_SIDE_PX=8192
# NEXA_MULTIMODAL_TEMP_TTL_SECONDS=3600
# NEXA_MULTIMODAL_STRIP_IMAGE_METADATA=false

# Phase 20 — optional CLI defaults (python -m nexa_cli)
# NEXA_API_BASE=http://127.0.0.1:8000
# NEXA_CLI_USER_ID=dev_user

# Dev workflow (aligns with Nexa Next Phase 16 — firewall stays on)
# NEXA_WORKSPACE_MODE=developer
# NEXA_APPROVALS_ENABLED=false
# NEXA_AGENT_TOOLS_ENABLED=true

# Web UI: optional status banner text (see web/components/nexa/ProjectStatusBanner.tsx)
# NEXT_PUBLIC_NEXA_STATUS_BANNER=Nexa Next — Experimental · Developer-first · Privacy-first architecture
# NEXT_PUBLIC_NEXA_HIDE_STATUS_BANNER=false

# scripts/nexa_next_local_all.sh start — runs API + Next.js; starts the Telegram bot automatically when
# TELEGRAM_BOT_TOKEN is set above. Set to 0 (or false / no) to run only API + web.
# NEXA_NEXT_START_BOT=0

# --- Phase 54 — safety defaults (bootstrap may merge similar lines) ---
# NEXA_SANDBOX_MODE=process
# NEXA_REQUIRE_SANDBOX_FOR_SKILLS=false
# NEXA_CREDENTIAL_VAULT_PROVIDER=local
# NEXA_NETWORK_EGRESS_MODE=allowlist
# NEXA_NETWORK_ALLOWED_HOSTS=api.openai.com,api.anthropic.com,localhost,127.0.0.1
# NEXA_VOICE_TRANSCRIBE_PROVIDER=local

# --- Open core / commercial tier (optional) — see docs/OPEN_CORE_EXTENSIONS.md
# NEXA_LICENSE_KEY=
# NEXA_LICENSE_PUBLIC_KEY_PEM=
