# Maximum autonomy — merge into .env (append:  cat env.autonomy.example >> .env)
# TRUSTED personal machine only: auto-approves dev jobs, auto review, optional auto commit for all.
#
# Two layouts:
# (A) API + bot run on the host (run_dev_stack / venv): keep OPERATOR_AUTO_RUN_DEV_EXECUTOR=true.
#     Codex or DEV_AGENT_COMMAND runs in the same environment as the API.
#
# (B) API + bot in Docker, Codex on the Mac: set OPERATOR_AUTO_RUN_DEV_EXECUTOR=false in .env
#     so the container does not run the Python executor. Then on the host run:
#       ./scripts/host_dev_executor_loop.sh
#     It uses the same repo + .agent_tasks and connects to Postgres on localhost:POSTGRES_HOST_PORT.

OPERATOR_POLL_SECONDS=20
OPERATOR_AUTO_RUN_LOCAL_TOOLS=true
OPERATOR_AUTO_RUN_DEV_EXECUTOR=true

# Auto chain (minimizes "approve job #N" in Telegram)
OPERATOR_AUTO_APPROVE_QUEUED_DEV_JOBS=true
OPERATOR_AUTO_APPROVE_REVIEW=true
OPERATOR_AUTO_APPROVE_COMMIT_SAFE=true
OPERATOR_AUTO_APPROVE_ALL_COMMITS=true

# Optional: non-interactive agent (stdin = dev prompt). Overrides Codex when set.
# DEV_AGENT_COMMAND=

# For Docker+host executor: uncomment these and run ./scripts/host_dev_executor_loop.sh
# OPERATOR_AUTO_RUN_DEV_EXECUTOR=false
# DEV_EXECUTOR_ON_HOST=1
# POSTGRES_HOST_PORT=5433
# (Host script sets DATABASE_URL to 127.0.0.1:POSTGRES_HOST_PORT — see script header.)
