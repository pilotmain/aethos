# Copy to .env next to docker-compose.yml:  cp env.docker.example .env
# DATABASE_URL is set inside docker-compose.yml to use the bundled Postgres (overrides any sqlite line here).

TELEGRAM_BOT_TOKEN=
USE_REAL_LLM=false
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Postgres: published port on your machine (container still listens on 5432 internally; api/bot use `db:5432`).
# Default in docker-compose is 5433 to avoid clashing with a local PostgreSQL on 5432. Set 5432 if you prefer.
# Used by scripts/host_dev_executor_loop.sh to reach DB from the host.
POSTGRES_USER=overwhelm
POSTGRES_PASSWORD=overwhelm
POSTGRES_DB=overwhelm
# One-command setup uses 5434 by default; avoid clashes with a local DB on 5432/5433. Override if needed.
POSTGRES_HOST_PORT=5434

# How often the API runs the operator (approvals, local tools, dev_agent_executor when enabled).
# Bot follow-ups use followup / TELEGRAM settings; for a stack that stays up: ./run_everything.sh start
OPERATOR_POLL_SECONDS=20

# In-container dev executor. Default in `python scripts/nexa_bootstrap.py` / README: use host for Codex — keep false in Docker.
OPERATOR_AUTO_RUN_DEV_EXECUTOR=false
# To merge full hands-off settings: see env.autonomy.example (and README "Maximum autonomy").
# OPERATOR_AUTO_APPROVE_QUEUED_DEV_JOBS=true
DEV_AGENT_COMMAND=

# Host dev executor: DEV_EXECUTOR_ON_HOST=1 + `run_everything.sh start` starts a host loop when you use the Mac.
# The API will not start in-container dev_agent_executor when the host runs the worker.
DEV_EXECUTOR_ON_HOST=1

# Workspace policy + host permission grants (technical reference: docs/WORKSPACE_AND_PERMISSIONS.md).
# Leave unset or false unless you intentionally require registered /workspace roots for every path.
# NEXA_WORKSPACE_STRICT=false
# HOST_EXECUTOR_WORK_ROOT=/path/visible/inside/the/api/container
